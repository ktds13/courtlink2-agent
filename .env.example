# CourtLink2 Agent - Environment Variables
# Copy this file to .env and fill in real values before running.

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── PostgreSQL + pgvector ─────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
# Default matches the docker-compose.yml setup
DATABASE_URL=postgresql://courtlink:courtlink@localhost:5432/courtlink2_agent

# ── CourtLink2 Management API ─────────────────────────────────────────────────
# Base URL of CourtLink2.Management (ASP.NET Core Kestrel, default port 5055)
COURTLINK_API_URL=https://localhost:5055

# mTLS client certificate for the agent identity (Monitor role)
# Leave empty to skip client cert auth (dev/test only — will fail against a
# production Management server that enforces mTLS)
COURTLINK_CERT_PATH=        # path to PEM/PFX client certificate file
COURTLINK_KEY_PATH=         # path to PEM private key file (if separate from cert)

# Set to "true" to disable TLS server certificate verification.
# ONLY use this in development against a self-signed Management cert.
COURTLINK_SSL_VERIFY=false

# ── Agent server ──────────────────────────────────────────────────────────────
# Host and port for the FastAPI server
AGENT_HOST=0.0.0.0
AGENT_PORT=8000

# ── RAG retrieval ─────────────────────────────────────────────────────────────
# Number of document chunks to retrieve per query
RAG_TOP_K=5
